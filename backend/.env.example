# Application
APP_NAME=OpenAssetGraph
APP_ENV=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database - Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Database - PostgreSQL
DATABASE_URL=postgresql://oag:oag123@localhost:5432/oag_metadata

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
# Provider options: openai, glm, kimi, deepseek, custom
LLM_PROVIDER=glm
LLM_MODEL=glm-4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
# Optional: Override base URL for custom endpoints
# LLM_BASE_URL=

# OpenAI API (also used as fallback)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# GLM API (Zhipu AI / 智谱AI)
# Get your API key from: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here

# Kimi API (Moonshot AI / 月之暗面)
# Get your API key from: https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key-here

# DeepSeek API
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]
